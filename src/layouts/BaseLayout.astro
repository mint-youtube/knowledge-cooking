---
import "../styles/global.css";
import { CHANNELS, getChannel } from "../data/channels";

interface Props {
  title: string;
  description?: string;
  channel?: string;
  ogImage?: string;
  pubDate?: Date;
}

const { title, description = "", channel, ogImage, pubDate } = Astro.props;
const ch = channel ? getChannel(channel) : undefined;
const dataChannelAttr = ch?.id ?? "";
const siteName = "Mint Soft Stories";
const fullTitle = ch ? `${title} | ${ch.name}` : `${title} | ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="ko" data-channel={dataChannelAttr}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="canonical" href={canonicalURL} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content={pubDate ? "article" : "website"} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <header class="site-header">
    <nav style="display:flex; gap:1.5rem; align-items:center; flex-wrap:wrap;">
      <a href="/" style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 700;">
        Mint Soft Stories
      </a>
      <span style="color: var(--muted); font-size: 0.85rem;">·</span>
      {Object.values(CHANNELS).map((c) => (
        <a
          href={`/${c.id}/`}
          style={`font-size: 0.85rem; color: ${ch?.id === c.id ? c.tokens.accent : "var(--muted)"}; font-weight: ${ch?.id === c.id ? "700" : "400"};`}
        >
          {c.emoji} {c.name}
        </a>
      ))}
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div style="max-width: var(--max-width); margin: 0 auto;">
      © {new Date().getFullYear()} Mint Soft Stories ·
      <a href="/rss.xml">RSS</a> ·
      <a href="/sitemap-index.xml">Sitemap</a>
    </div>
  </footer>
</body>
</html>
