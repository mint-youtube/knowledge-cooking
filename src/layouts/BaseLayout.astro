---
import "../styles/global.css";
import { CHANNEL } from "../data/channel";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
}

const { title, description = CHANNEL.tagline, ogImage, pubDate } = Astro.props;
const fullTitle = title ? `${title} | ${CHANNEL.name}` : CHANNEL.name;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="canonical" href={canonicalURL} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content={pubDate ? "article" : "website"} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" type="application/rss+xml" title={CHANNEL.name} href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo:wght@400;700;800&family=Nanum+Gothic:wght@400;700&display=swap">
  
  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-306ESBSX7Y"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-306ESBSX7Y');
  </script>
</head>
<body class="min-h-screen flex flex-col ">
  <header class="border-b border-border border-b-4 border-accent bg-bg-secondary">
    <div class="max-w-wide mx-auto px-5 py-5 flex items-center justify-between flex-wrap gap-3">
      <a href="/" class="font-heading font-extrabold text-2xl text-accent no-underline">{CHANNEL.emoji} {CHANNEL.name}</a>
      <nav class="flex gap-5"><a href="/" class="text-muted text-sm hover:text-accent">홈</a><a href="/tags/" class="text-muted text-sm hover:text-accent">레시피</a><a href="/about/" class="text-muted text-sm hover:text-accent">소개</a><a href={CHANNEL.youtubeUrl} target="_blank" rel="noopener" class="text-muted text-sm hover:text-accent">유튜브</a></nav>
    </div>
  </header>
  <main class="flex-1">
    <slot />
  </main>
  <footer class="border-t border-border mt-auto bg-bg-secondary/30">
    <div class="max-w-wide mx-auto px-5 py-10">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div>
          <h4 class="font-heading text-base mb-2 text-fg">{CHANNEL.name}</h4>
          <p class="text-sm text-muted">{CHANNEL.tagline}</p>
        </div>
        <div>
          <h4 class="font-heading text-sm mb-2 text-fg">탐색</h4>
          <ul class="space-y-1 text-sm">
            <li><a href="/" class="text-muted hover:text-accent">홈</a></li>
            <li><a href="/tags/" class="text-muted hover:text-accent">태그</a></li>
            <li><a href="/about/" class="text-muted hover:text-accent">소개</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-heading text-sm mb-2 text-fg">구독</h4>
          <ul class="space-y-1 text-sm">
            <li><a href="/rss.xml" class="text-muted hover:text-accent">RSS 피드</a></li>
            <li><a href="/sitemap-index.xml" class="text-muted hover:text-accent">Sitemap</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-border pt-5 text-center text-xs text-muted">
        © {new Date().getFullYear()} {CHANNEL.name} · All rights reserved.
      </div>
    </div>
  </footer>
</body>
</html>
