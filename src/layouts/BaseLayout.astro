---
import "../styles/global.css";
import { CHANNEL } from "../data/channel";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  pubDate?: Date;
}

const { title, description = CHANNEL.tagline, ogImage, pubDate } = Astro.props;
const fullTitle = title ? `${title} | ${CHANNEL.name}` : CHANNEL.name;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="canonical" href={canonicalURL} />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:type" content={pubDate ? "article" : "website"} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {pubDate && <meta property="article:published_time" content={pubDate.toISOString()} />}
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="alternate" type="application/rss+xml" title={CHANNEL.name} href="/rss.xml" />
  <link rel="sitemap" href="/sitemap-index.xml" />
</head>
<body>
  <header class="site-header">
    <nav style="display:flex; gap:1.5rem; align-items:center; justify-content: space-between; flex-wrap: wrap;">
      <a href="/" class="brand">
        <span style="font-size: 1.6rem;">{CHANNEL.emoji}</span>
        <span>{CHANNEL.name}</span>
      </a>
      <div style="display:flex; gap:1.5rem;">
        <a href="/" style="color: var(--muted); font-size: 0.9rem;">홈</a>
        <a href="/tags/" style="color: var(--muted); font-size: 0.9rem;">태그</a>
        <a href="/about/" style="color: var(--muted); font-size: 0.9rem;">소개</a>
      </div>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div style="max-width: var(--max-width); margin: 0 auto;">
      © {new Date().getFullYear()} {CHANNEL.name} ·
      <a href="/rss.xml">RSS</a> ·
      <a href="/sitemap-index.xml">Sitemap</a>
    </div>
  </footer>
</body>
</html>
