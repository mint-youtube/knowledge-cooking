---
import BaseLayout from "./BaseLayout.astro";
import CoupangAd from "../components/CoupangAd.astro";
import AliExpressAd from "../components/AliExpressAd.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  tags?: string[];
  youtubeUrl?: string;
  heroImage?: string;
}

const { title, description, pubDate, updatedDate, tags = [], youtubeUrl, heroImage } = Astro.props;
const formattedDate = pubDate.toLocaleDateString("ko-KR", { year: "numeric", month: "long", day: "numeric" });
---
<BaseLayout title={title} description={description} ogImage={heroImage} pubDate={pubDate}>
  <article class="prose post-article">
    <h1 class="post-title">{title}</h1>
    <p class="post-meta">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {updatedDate && (<span> · 수정 {updatedDate.toLocaleDateString("ko-KR")}</span>)}
    </p>
    {tags.length > 0 && (
      <p class="post-tags">
        {tags.map((t) => (
          <a href={`/tags/${t}/`} class="tag-chip">#{t}</a>
        ))}
      </p>
    )}
    {heroImage && (<img class="post-hero" src={heroImage} alt={title} />)}
    <div class="ad-coupang"><CoupangAd /></div>
    <div class="post-body"><slot /></div>
    <div class="ad-aliexpress"><AliExpressAd /></div>
    {youtubeUrl && (
      <div class="youtube-cta">
        <p>📺 영상으로 보기</p>
        <a href={youtubeUrl} target="_blank" rel="noopener">{youtubeUrl}</a>
      </div>
    )}
  </article>
</BaseLayout>


