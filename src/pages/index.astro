---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CHANNEL } from "../data/channel";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout>
  <section class="text-center py-16 px-5 max-w-wide mx-auto border-b border-border">
    <div class="text-5xl mb-3">{CHANNEL.emoji}</div>
    <h1 class="font-heading text-4xl md:text-5xl font-black tracking-tight mb-3">{CHANNEL.name}</h1>
    <p class="text-muted text-base md:text-lg max-w-prose mx-auto">{CHANNEL.tagline}</p>
  </section>

  <section class="max-w-wide mx-auto px-5 py-10">
    {posts.length === 0 && <p class="text-center text-muted py-12">아직 글이 없습니다.</p>}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((p) => (
        <a href={`/posts/${p.slug}/`} class="group block p-6 bg-bg-secondary border border-border rounded-xl transition-all duration-200 hover:-translate-y-1 hover:border-accent hover:shadow-2xl no-underline">
          <h3 class="font-heading text-lg leading-snug mb-2 line-clamp-2 text-fg group-hover:text-accent transition">{p.data.title}</h3>
          <p class="text-sm text-muted line-clamp-3 leading-relaxed">{p.data.description}</p>
          {p.data.tags && p.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-1.5 mt-3">
              {p.data.tags.slice(0, 3).map((t) => (
                <span class="text-xs px-2 py-0.5 rounded-md bg-hover text-muted">#{t}</span>
              ))}
            </div>
          )}
          <p class="text-xs text-muted mt-4 pt-3 border-t border-border">
            <time>{p.data.pubDate.toLocaleDateString("ko-KR")}</time>
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
