---
import BaseLayout from "../layouts/BaseLayout.astro";
import { CHANNEL } from "../data/channel";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout>
  <section class="home-hero">
    <div class="home-emoji">{CHANNEL.emoji}</div>
    <h1 class="home-title">{CHANNEL.name}</h1>
    <p class="home-tagline">{CHANNEL.tagline}</p>
  </section>

  <section class="home-posts">
    {posts.length === 0 && <p class="home-empty">아직 글이 없습니다.</p>}
    <div class="grid">
      {posts.map((p) => (
        <a href={`/${p.slug}/`} class="card">
          <h3>{p.data.title}</h3>
          <p>{p.data.description}</p>
          <p class="meta">
            <time>{p.data.pubDate.toLocaleDateString("ko-KR")}</time>
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

