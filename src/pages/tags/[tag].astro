---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const tags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => (p.data.tags || []).includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`}>
  <section class="prose tag-page">
    <h1>#{tag}</h1>
    <p class="tag-count">{posts.length}개 글</p>
    <div class="grid">
      {posts.map((p) => (
        <a href={`/${p.slug}/`} class="card">
          <h3>{p.data.title}</h3>
          <p>{p.data.description}</p>
          <p class="meta">
            <time>{p.data.pubDate.toLocaleDateString("ko-KR")}</time>
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
.tag-page { padding: 2rem 1.25rem; }
.tag-count { color: var(--muted); margin-bottom: 1.5rem; }

</style>