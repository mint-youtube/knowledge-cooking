---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const tags = [...new Set(posts.flatMap((p) => p.data.tags || []))];
  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => (p.data.tags || []).includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---
<BaseLayout title={`#${tag}`}>
  <section class="max-w-wide mx-auto px-5 py-12">
    <p class="text-muted text-sm mb-2"><a href="/tags/" class="no-underline hover:text-accent">← 모든 태그</a></p>
    <h1 class="font-heading text-3xl mb-2">#{tag}</h1>
    <p class="text-muted mb-8">{posts.length}개 글</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {posts.map((p) => (
        <a href={`/posts/${p.slug}/`} class="group block p-6 bg-bg-secondary border border-border rounded-xl transition hover:-translate-y-1 hover:border-accent hover:shadow-2xl no-underline">
          <h3 class="font-heading text-lg leading-snug mb-2 line-clamp-2 text-fg group-hover:text-accent">{p.data.title}</h3>
          <p class="text-sm text-muted line-clamp-3 leading-relaxed">{p.data.description}</p>
          <p class="text-xs text-muted mt-4 pt-3 border-t border-border">
            <time>{p.data.pubDate.toLocaleDateString("ko-KR")}</time>
          </p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
